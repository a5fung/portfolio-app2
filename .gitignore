# Secrets — NEVER commit. Set these in Streamlit Cloud (Settings → Secrets) for
# the deployed app, and keep a local .streamlit/secrets.toml (ignored) for local runs.
.streamlit/secrets.toml
.streamlit/secrets*.toml

